    call _w14
    cmp byte [FAILED], 1
    je .seq_fail_19
    call _w15
    cmp byte [FAILED], 1
    je .seq_fail_19
    call _w16
    cmp byte [FAILED], 1
    je .seq_fail_19
    call _w17
    cmp byte [FAILED], 1
    je .seq_fail_19
    call _w18
    cmp byte [FAILED], 1
    je .seq_fail_19
    jmp .seq_ok_19
.seq_fail_19:
    call restore_inp
    mov byte [FAILED], 1
.seq_ok_19:
    ret
_w21:
    mov rdi, 123
    call match_cp
    ret
_w22:
    call ws
    ret
_w23:
    mov rdi, 125
    call match_cp
    ret
_w25:
    call save_inp
    call _w21
    cmp byte [FAILED], 1
    je .seq_fail_24
    call _w22
    cmp byte [FAILED], 1
    je .seq_fail_24
    call _w23
    cmp byte [FAILED], 1
    je .seq_fail_24
    jmp .seq_ok_24
.seq_fail_24:
    call restore_inp
    mov byte [FAILED], 1
.seq_ok_24:
    ret
_w27:
