    call _w29
    cmp byte [FAILED], 1
    je .seq_fail_32
    call _w30
    cmp byte [FAILED], 1
    je .seq_fail_32
    call _w31
    cmp byte [FAILED], 1
    je .seq_fail_32
    jmp .seq_ok_32
.seq_fail_32:
    call restore_inp
    mov byte [FAILED], 1
.seq_ok_32:
    ret
_w34:
    mov rdi, _w33
    call peg_star
    ret
_w36:
    call ws
    ret
_w37:
    call string
    ret
_w38:
    call ws
    ret
_w39:
    mov rdi, 58
    call match_cp
    ret
_w40:
    call ws
    ret
_w41:
    call value
    ret
_w42:
    call ws
